---
// Bloque OPCIONAL de reserva online. Solo se muestra si
// business.onlineBooking.enabled === true (ver config/business.ts).
import business from '../config/business';
const { onlineBooking } = business;
---
{onlineBooking?.enabled && onlineBooking.url && (
  <section id="reserva" class="booking">
    <div class="container">
      <div class="section-title">
        <span>Reserva online</span>
        <h2>Elige día y hora</h2>
      </div>
      <div class="frame">
        <iframe src={onlineBooking.url} title="Reserva online" loading="lazy"></iframe>
      </div>
    </div>
  </section>
)}

<style>
  .frame { border-radius: 16px; overflow: hidden; min-height: 620px; box-shadow: 0 8px 30px rgba(0,0,0,.08); }
  .frame iframe { width: 100%; height: 100%; min-height: 620px; border: 0; }
</style>
