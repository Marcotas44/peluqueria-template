---
import business from '../config/business';
const { name, tagline, city, category, heroImage, phoneRaw, phone, whatsapp, whatsappMessage, googleRating } = business;
const waLink = `https://wa.me/${whatsapp}?text=${encodeURIComponent(whatsappMessage)}`;
---
<section id="inicio" class="hero">
  <div class="overlay"></div>
  <div class="container content">
    <p class="eyebrow">{category} de confianza en {city} · Ferrol</p>
    <h1>{name}</h1>
    <p class="tagline">{tagline}</p>
    <div class="actions">
      <a class="btn btn-wa" href={waLink} target="_blank" rel="noopener">💬 Pedir cita por WhatsApp</a>
      <a class="btn btn-outline light" href={`tel:${phoneRaw}`}>📞 Llamar {phone}</a>
    </div>

    <ul class="trust">
      {googleRating && (
        <li><strong>★ {googleRating.score}</strong> · {googleRating.count} reseñas en Google</li>
      )}
      <li>✓ Producto profesional de primeras marcas</li>
      <li>✓ Cita por WhatsApp en menos de 60 s</li>
    </ul>
  </div>
  <a href="#reserva-rapida" class="scroll" aria-label="Ver más">↓</a>
</section>

<style define:vars={{ bg: `url('${heroImage}')` }}>
  .hero {
    position: relative;
    min-height: 92vh;
    display: flex; align-items: center;
    background-image: var(--bg);
    background-size: cover; background-position: center;
    color: #fff;
  }
  .overlay {
    position: absolute; inset: 0;
    background:
      linear-gradient(120deg, rgba(0,0,0,.82) 0%, rgba(0,0,0,.45) 55%, rgba(0,0,0,.25) 100%),
      linear-gradient(to top, rgba(0,0,0,.6), rgba(0,0,0,0) 40%);
  }
  .content {
    position: relative; z-index: 2; max-width: 760px;
    animation: rise .8s ease both;
  }
  @keyframes rise { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: none; } }

  .eyebrow {
    font-family: var(--font);
    text-transform: uppercase; letter-spacing: 3px;
    font-size: .82rem; color: var(--accent); font-weight: 600;
  }
  h1 {
    font-size: clamp(3rem, 8.5vw, 5.4rem);
    margin: 10px 0 6px;
    text-shadow: 0 2px 30px rgba(0,0,0,.4);
  }
  .tagline {
    font-family: var(--font);
    font-size: clamp(1.05rem, 2.4vw, 1.45rem);
    opacity: .94; margin-bottom: 30px; max-width: 640px;
    line-height: 1.55;
  }
  .actions { display: flex; flex-wrap: wrap; gap: 14px; }
  .btn-outline.light { border-color: rgba(255,255,255,.7); color: #fff; }
  .btn-outline.light:hover { background: rgba(255,255,255,.1); }

  .trust {
    list-style: none; display: flex; flex-wrap: wrap;
    gap: 10px 22px; margin-top: 30px;
    font-size: .92rem; font-weight: 500;
  }
  .trust li { display: inline-flex; align-items: center; gap: 6px; opacity: .94; }
  .trust strong { color: var(--accent); font-weight: 700; }
  .trust li:not(:first-child) { color: rgba(255,255,255,.85); }

  .scroll {
    position: absolute; left: 50%; bottom: 22px; transform: translateX(-50%);
    z-index: 2; width: 42px; height: 42px; border-radius: 50%;
    display: grid; place-items: center;
    border: 1px solid rgba(255,255,255,.5); color: #fff;
    font-size: 1.1rem; animation: bob 1.8s ease-in-out infinite;
  }
  @keyframes bob { 0%,100% { transform: translate(-50%, 0); } 50% { transform: translate(-50%, 7px); } }
  @media (max-width: 820px) { .scroll { display: none; } }
</style>
