---
import business from '../config/business';
const { name, address, phone, phoneRaw, email, mapsUrl, instagram, whatsapp, whatsappMessage, city } = business;
const waLink = `https://wa.me/${whatsapp}?text=${encodeURIComponent(whatsappMessage)}`;
const year = new Date().getFullYear();
---
<footer>
  <div class="container grid grid-3">
    <div>
      <h3>{name}</h3>
      <p class="muted">{address}</p>
    </div>
    <div>
      <h4>Contacto</h4>
      <p><a href={`tel:${phoneRaw}`}>{phone}</a></p>
      <p><a href={`mailto:${email}`}>{email}</a></p>
      <p><a href={waLink} target="_blank" rel="noopener">WhatsApp</a></p>
    </div>
    <div>
      <h4>Enlaces</h4>
      <p><a href={mapsUrl} target="_blank" rel="noopener">Google Maps</a></p>
      {instagram && <p><a href={instagram} target="_blank" rel="noopener">Instagram</a></p>}
    </div>
  </div>
  <div class="bottom">
    <p>© {year} {name} · {city} · Todos los derechos reservados</p>
  </div>
</footer>

<style>
  footer { background: var(--primary); color: #fff; padding: 54px 0 0; }
  footer h3 { color: var(--accent); margin-bottom: 8px; }
  footer h4 { margin-bottom: 10px; font-size: .95rem; text-transform: uppercase; letter-spacing: 1px; }
  footer a:hover { color: var(--accent); }
  footer .muted { color: rgba(255,255,255,.6); }
  .bottom { border-top: 1px solid rgba(255,255,255,.12); margin-top: 32px; padding: 20px 0; text-align: center; font-size: .85rem; color: rgba(255,255,255,.6); }
</style>
