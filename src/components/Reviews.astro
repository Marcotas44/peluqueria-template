---
import business from '../config/business';
const { reviews, googleRating, mapsUrl } = business;
const stars = (n) => '★'.repeat(n) + '☆'.repeat(5 - n);
const initials = (name) =>
  name.split(' ').filter(Boolean).slice(0, 2).map((w) => w[0]).join('').toUpperCase();
---
<section id="opiniones" class="reviews">
  <div class="container">
    <div class="section-title">
      <span>Opiniones reales</span>
      <h2>Lo que dicen nuestros clientes</h2>
    </div>

    {googleRating && (
      <div class="rating-banner">
        <div class="score">{googleRating.score.toFixed(1)}</div>
        <div class="meta">
          <p class="stars">{stars(Math.round(googleRating.score))}</p>
          <p class="muted">Basado en {googleRating.count} reseñas en Google</p>
        </div>
        <span class="gbadge">Google</span>
      </div>
    )}

    <div class="grid grid-3">
      {reviews.map((r) => (
        <figure class="card review">
          <span class="quote">“</span>
          <p class="stars">{stars(r.rating)}</p>
          <blockquote>{r.text}</blockquote>
          <figcaption class="who">
            <span class="avatar">{initials(r.author)}</span>
            <span class="id">
              <span class="author">{r.author}</span>
              <span class="verified">✓ Cliente verificada</span>
            </span>
          </figcaption>
        </figure>
      ))}
    </div>

    <div style="text-align:center; margin-top:36px">
      <a class="btn btn-outline" href={mapsUrl} target="_blank" rel="noopener">Ver todas las reseñas en Google</a>
    </div>
  </div>
</section>

<style>
  .reviews { background: #faf8f4; }

  .rating-banner {
    display: flex; align-items: center; gap: 18px;
    max-width: 460px; margin: 0 auto 40px;
    background: #fff; border: 1px solid rgba(0,0,0,.06);
    border-radius: 16px; padding: 18px 24px;
    box-shadow: 0 10px 34px rgba(0,0,0,.06);
  }
  .rating-banner .score { font-family: var(--font-display); font-size: 2.8rem; font-weight: 700; color: var(--primary); line-height: 1; }
  .rating-banner .stars { color: var(--accent); font-size: 1.05rem; letter-spacing: 2px; }
  .rating-banner .meta { flex: 1; }
  .rating-banner .muted { font-size: .85rem; }
  .gbadge {
    font-weight: 700; font-size: .85rem; letter-spacing: .5px;
    color: #4285F4; border: 1px solid rgba(0,0,0,.08);
    padding: 6px 12px; border-radius: 999px; background: #fff;
  }

  .review { position: relative; display: flex; flex-direction: column; padding-top: 30px; }
  .review .quote {
    position: absolute; top: 6px; left: 22px;
    font-family: var(--font-display); font-size: 4rem; line-height: 1;
    color: var(--accent); opacity: .28;
  }
  .review .stars { color: var(--accent); font-size: 1.05rem; letter-spacing: 2px; margin-bottom: 10px; }
  .review blockquote { font-size: 1rem; line-height: 1.6; margin-bottom: 18px; flex: 1; }

  .who { display: flex; align-items: center; gap: 12px; margin-top: auto; }
  .avatar {
    width: 44px; height: 44px; border-radius: 50%;
    display: grid; place-items: center; flex-shrink: 0;
    background: linear-gradient(135deg, var(--accent), #b1924f);
    color: #161616; font-weight: 700; font-size: .95rem;
    font-family: var(--font);
  }
  .id { display: flex; flex-direction: column; }
  .author { font-weight: 600; color: var(--dark); }
  .verified { font-size: .78rem; color: #1a7f37; font-weight: 500; }

  @media (max-width: 820px) {
    .rating-banner { max-width: 100%; }
  }
</style>
