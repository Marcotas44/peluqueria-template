---
import business from '../config/business';
const { whatsapp, whatsappMessage, phoneRaw } = business;
const waLink = `https://wa.me/${whatsapp}?text=${encodeURIComponent(whatsappMessage)}`;
---
<div class="floating">
  <a class="fab wa" href={waLink} target="_blank" rel="noopener" aria-label="WhatsApp">💬</a>
  <a class="fab call" href={`tel:${phoneRaw}`} aria-label="Llamar">📞</a>
</div>

<style>
  .floating { position: fixed; right: 18px; bottom: 18px; z-index: 60; display: flex; flex-direction: column; gap: 12px; }
  .fab {
    width: 56px; height: 56px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.5rem; color: #fff;
    box-shadow: 0 6px 20px rgba(0,0,0,.25);
    transition: transform .15s ease;
  }
  .fab:hover { transform: scale(1.08); }
  .wa { background: #25D366; }
  .call { background: var(--primary); }
</style>
