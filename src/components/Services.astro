---
import business from '../config/business';
const { services, whatsapp, whatsappMessage } = business;
const waLink = `https://wa.me/${whatsapp}?text=${encodeURIComponent(whatsappMessage)}`;
---
<section id="servicios" class="services">
  <div class="container">
    <div class="section-title">
      <span>Lo que hacemos</span>
      <h2>Servicios y precios</h2>
    </div>
    <div class="grid grid-3">
      {services.map((s) => (
        <div class="card service">
          <div class="top">
            <h3>{s.name}</h3>
            <span class="price">{s.price}</span>
          </div>
          {s.duration && <p class="muted dur">⏱ {s.duration}</p>}
          {s.description && <p class="muted">{s.description}</p>}
        </div>
      ))}
    </div>
    <div style="text-align:center; margin-top:36px">
      <a class="btn btn-dark" href={waLink} target="_blank" rel="noopener">Reservar un servicio</a>
    </div>
  </div>
</section>

<style>
  .service .top { display: flex; justify-content: space-between; align-items: baseline; gap: 10px; }
  .service h3 { font-size: 1.05rem; }
  .price { color: var(--accent); font-weight: 700; white-space: nowrap; }
  .dur { font-size: .85rem; margin-top: 6px; }
</style>
