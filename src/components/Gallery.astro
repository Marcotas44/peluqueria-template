---
import business from '../config/business';
const { gallery } = business;
---
<section id="galeria" class="gallery">
  <div class="container">
    <div class="section-title">
      <span>Nuestro trabajo</span>
      <h2>Galería</h2>
    </div>
    <div class="masonry">
      {gallery.map((g) => (
        <figure>
          <img src={g.src} alt={g.alt} loading="lazy" />
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .masonry {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }
  figure { overflow: hidden; border-radius: 14px; aspect-ratio: 1; }
  figure img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s ease; }
  figure:hover img { transform: scale(1.06); }
  @media (max-width: 820px) { .masonry { grid-template-columns: repeat(2, 1fr); } }
</style>
